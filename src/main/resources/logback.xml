<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Pattern definition -->
    <property name="DEFAULT_PATTERN"
          value="%-90(%d{(yyyy-MM-dd -- HH:mm:ss.SSS)} %+10logger{10}.%-10M) [ %-5level ]  %msg%n"/>

    <!-- Log level from environment variable, default to WARN -->
    <property name="LOG_LEVEL" value="${LOG_LEVEL:-WARN}"/>

    <!-- Console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${DEFAULT_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- File appender with rotation -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>appdata/logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>appdata/logs/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <totalSizeCap>200MB</totalSizeCap>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${DEFAULT_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Application code: uses the configured LOG_LEVEL (TRACE / DEBUG / INFO / WARN / ERROR) -->
    <logger name="org.soynx.mcp" level="${LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Everything else (Spring, Kohsuke GitHub API, etc.) stays at INFO regardless of LOG_LEVEL -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
