services:
  knowledge-github-mcp:
    image: ghcr.io/soynx/knowledge-github-mcp:latest
    ports:
      - "8080:8080"
    environment:
      # GitHub Personal Access Token (read-only, repo scope)
      - GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

      # Your Obsidian vault repository in "username/repo-name" format
      - GITHUB_REPOSITORY=youruser/obsidian-vault

      # Optional: subfolder within the repo where the vault lives.
      # Leave empty if the vault is at the repository root.
      - VAULT_ROOT=

      # SLF4J Loglevel (TRACE, DEBUG, INFO, WARN, ERROR)
      - LOG_LEVEL=INFO
    restart: unless-stopped

    # OPTIONAL: mount logs
    # volumes:
    #   - /path/to/your/volume:/app/appdata/logs

    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/actuator/health"]
      interval: 60s
      timeout: 5s
      retries: 3
